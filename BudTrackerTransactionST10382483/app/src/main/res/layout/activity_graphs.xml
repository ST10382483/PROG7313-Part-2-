<?xml version="1.0" encoding="utf-8"?>

<!-- Root layout for the entire graph screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Scrollable content so the page works on smaller screens -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <!-- Main container for all UI elements -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5">

            <!-- Top blue header section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="#0F3D3E"
                android:gravity="center">

                <!-- Image shown in the center of the header -->
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Screen title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spending Overview"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_margin="16dp"
                android:textColor="#000000"/>

            <!-- Pie chart used to visually display spending -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Transport category row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Category name -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Transport"
                    android:textSize="16sp"/>

                <!-- Amount for Transport -->
                <TextView
                    android:id="@+id/txtTransport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R500"/>
            </LinearLayout>

            <!-- Takeout category row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Takeout"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/txtTakeout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R300"/>
            </LinearLayout>

            <!-- Groceries category row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Groceries"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/txtGroceries"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R700"/>
            </LinearLayout>

            <!-- Personal Shopping category row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Personal Shopping"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/txtPersonal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R200"/>
            </LinearLayout>

            <!-- Button to navigate to Create Transaction screen -->
            <Button
                android:id="@+id/btnAddMore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add More"
                android:layout_margin="16dp"
                android:backgroundTint="#0F3D3E"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation menu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:weightSum="4">

        <!-- Home navigation item -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Card navigation item -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Profile navigation item -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Alerts navigation item -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alerts"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>