<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A"
    android:gravity="center"
    android:padding="24dp">

    <ImageView
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="24dp"
        android:layout_marginTop="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete Account"
            android:textColor="#EF5350"
            android:textStyle="bold"
            android:textSize="26sp"
            android:gravity="center" />

        <!-- Confirmation message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Are you sure you want to delete your account?"
            android:textColor="#EF5350"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="10dp" />

        <!-- Instruction to enter password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please enter your password to confirm:"
            android:textColor="#EF5350"
            android:textStyle="bold"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="25dp" />

        <!-- Warning message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WARNING: You will lose all collected data."
            android:textColor="#EF5350"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="10dp" />

        <!-- Password input field -->
        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:inputType="textPassword"
            android:textColor="#000000"
            android:backgroundTint="#2ECC71"
            android:layout_marginTop="20dp" />

    </LinearLayout>

    <!-- Button to go back -->
    <Button
        android:id="@+id/backHomeBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Go back to Home Page"
        android:backgroundTint="#2ECC71"
        android:textColor="#FFFFFF"
        android:layout_marginTop="40dp" />

    <!-- Button to confirm deletion -->
    <Button
        android:id="@+id/deleteAccountBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Account"
        android:backgroundTint="#EF5350"
        android:textColor="#FFFFFF"
        android:layout_marginTop="15dp" />

</LinearLayout>