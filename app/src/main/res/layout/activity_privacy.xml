<?xml version="1.0" encoding="utf-8"?>

<!-- Privacy settings screen  -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <!-- App logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter" />

    <!-- Main content section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/logo"
        android:layout_marginTop="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp">

        <!-- Page title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Privacy Settings"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Placeholder message -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This feature will be introduced later in the BudTrackr prototype."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginTop="40dp" />

        <!-- Additional info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Future updates will include account privacy, data security, and user protection settings."
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="25dp" />

        <!-- Back button -->
        <Button
            android:id="@+id/btnHome"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#42C978"
            android:layout_marginTop="80dp" />

    </LinearLayout>

</RelativeLayout>