<?xml version="1.0" encoding="utf-8"?>

<!-- Reset account password screen -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center_horizontal">

        <!-- App logo -->
        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter" />

        <!-- Page title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset Account Password"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="40dp" />

        <!-- Instruction text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter your username or email:"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="40dp" />

        <!-- Email / username input -->
        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Email Address"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:backgroundTint="#2ECC71"
            android:layout_marginTop="15dp" />

        <!-- Info message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A reset process will be triggered for this account."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="30dp" />

        <!-- Reset button -->
        <Button
            android:id="@+id/resetAccountBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESET ACCOUNT"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFA94D"
            android:layout_marginTop="25dp" />

    </LinearLayout>
</ScrollView>