<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#071A2F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:text="View Expenses"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Description -->
        <TextView
            android:text="View all your expense entries for a selected period."
            android:textColor="@android:color/white"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Button to add a new expense -->
        <Button
            android:id="@+id/btnAddExpense"
            android:text="+ Add New Expense"
            android:backgroundTint="#2EAD5B"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Filter section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp">

            <!-- Date range inputs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Start date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:text="Start Date:"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#10233D"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/edtStartDate"
                        android:hint="Select date"
                        android:textSize="13sp"
                        android:focusable="false"
                        android:inputType="none"
                        android:background="#F5F5F5"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="45dp" />
                </LinearLayout>

                <!-- End date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:text="End Date:"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#10233D"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/edtEndDate"
                        android:hint="Select date"
                        android:textSize="13sp"
                        android:focusable="false"
                        android:inputType="none"
                        android:background="#F5F5F5"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="45dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Filterand Reset buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnFilter"
                    android:text="Filter"
                    android:backgroundTint="#247A3D"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="45dp" />

                <Button
                    android:id="@+id/btnReset"
                    android:text="Reset"
                    android:backgroundTint="#D32F2F"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="45dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Summary section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="3">

            <TextView
                android:id="@+id/txtTotalExpenses"
                android:text="Total Expenses\nR 0.00"
                android:gravity="center"
                android:background="#F1FFF4"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="80dp" />

            <TextView
                android:id="@+id/txtTransactions"
                android:text="Transactions\n0"
                android:gravity="center"
                android:background="#F1FFF4"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="80dp" />

            <TextView
                android:id="@+id/txtPeriod"
                android:text="Period\n-"
                android:gravity="center"
                android:background="#F1FFF4"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="80dp" />
        </LinearLayout>

        <!-- Expense list section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="18dp"
            android:background="@android:color/white"
            android:padding="14dp">

            <TextView
                android:text="Expense List"
                android:textColor="#10233D"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- List of expenses -->
            <LinearLayout
                android:id="@+id/listExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Back button -->
        <Button
            android:id="@+id/btnBack"
            android:text="Back"
            android:backgroundTint="#FFFFFF"
            android:textColor="#071A2F"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>